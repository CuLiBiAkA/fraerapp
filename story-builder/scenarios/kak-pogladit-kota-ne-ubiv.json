  "scenes": [
    {
      "id": "start",
      "title": "Операция «Бархатная лапа»",
      "text": "Перед тобой кот. Он лежит на диване так, будто это он платит ипотеку. Цель проста: погладить кота и не разрушить международные отношения между человеком и шерстью.",
      "variables": {},
      "assets": [
        { "id": "local_rulebook", "type": "image", "url": "/assets/board.svg", "metadata": { "caption": "Правило №1: кот не обязан быть гладимым" } }
