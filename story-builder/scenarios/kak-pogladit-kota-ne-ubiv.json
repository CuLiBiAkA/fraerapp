      "background": "bg_room",
      "music": "music_purr",
      "animation": { "type": "fade-in", "durationMs": 700 },
      "effects": [],
      "choices": [
        { "id": "observe", "label": "Сначала прочитать кота как древний манускрипт", "target": "observe", "conditions": [], "effects": [{ "inc": "trust", "value": 1 }, { "inc": "cat_mood", "value": 1 }] },
        { "id": "rush", "label": "Сразу тянуть руку: я же добрый", "target": "rush", "conditions": [], "effects": [{ "inc": "noise", "value": 2 }, { "inc": "scratches", "value": 1 }] }
      ]
    },
    {
