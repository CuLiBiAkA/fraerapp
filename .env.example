NGINX_CONF=nginx.local.conf
HOST_BIND_IP=127.0.0.1
BUILDER_BIND_IP=127.0.0.1
HTTP_PORT=8088
HTTPS_PORT=443
BUILDER_PORT=8090
APP_BIND_IP=127.0.0.1
AUTH_JWT_SECRET=change-this-long-random-shared-secret
POSTGRES_DB=fraerapp
POSTGRES_USER=fraerapp
POSTGRES_PASSWORD=change-this-api-db-password
AUTH_POSTGRES_DB=fraerapp_auth
AUTH_POSTGRES_USER=fraerapp_auth
AUTH_POSTGRES_PASSWORD=change-this-auth-db-password
# Empty means magic links use the current request host, so localhost and LAN IP both work.
AUTH_PUBLIC_BASE_URL=
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_PRIVACY_POLICY_VERSION=2026-06-21
AUTH_DEV_MODE=true
AUTH_MANUAL_LOGIN_LINKS=false
# Production no-SMTP fallback: log links only for an existing admin or AUTH_BOOTSTRAP_ADMIN_EMAIL.
AUTH_ADMIN_LOGIN_LINK_LOG_ENABLED=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_PASSKEY_RP_ID=localhost
AUTH_PASSKEY_RP_NAME=FraerApp
AUTH_PASSKEY_ORIGINS=http://localhost:8088,http://localhost:8090
AUTH_PASSKEY_CHALLENGE_TTL_SECONDS=300
AUTH_PASSKEY_REGISTRATION_RECENT_AUTH_SECONDS=600
AUTH_TELEGRAM_BOT_ENABLED=false
AUTH_TELEGRAM_BOT_TOKEN=
AUTH_TELEGRAM_BOT_USERNAME=culibiaka_bot
AUTH_TELEGRAM_WEBHOOK_SECRET=change-this-telegram-webhook-secret
AUTH_TELEGRAM_LOGIN_REDIRECT_PATH=/
CORS_ALLOWED_ORIGINS=http://localhost:8088,https://localhost,http://127.0.0.1:8088,https://127.0.0.1,http://localhost:8090,http://127.0.0.1:8090
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:8088,https://localhost,http://127.0.0.1:8088,https://127.0.0.1,http://localhost:8090,http://127.0.0.1:8090
MAIL_HOSTNAME=mail.fraerapp.ru
SMTP_HOST=mailserver
SMTP_PORT=587
SMTP_USERNAME=noreply@fraerapp.ru
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM=noreply@fraerapp.ru
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=true
SMTP_HEALTH_ENABLED=true

# Observability stack, enabled with:
# docker compose up -d --build
GRAFANA_BIND_IP=0.0.0.0
OBSERVABILITY_INTERNAL_BIND_IP=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
LOKI_PORT=3100
