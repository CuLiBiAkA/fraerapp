NGINX_CONF=nginx.prod.conf
HOST_BIND_IP=0.0.0.0
BUILDER_BIND_IP=127.0.0.1
HTTP_PORT=80
HTTPS_PORT=443
BUILDER_PORT=8090
AUTH_JWT_SECRET=change-this-long-random-shared-secret
POSTGRES_DB=fraerapp
POSTGRES_USER=fraerapp
POSTGRES_PASSWORD=change-this-api-db-password
AUTH_POSTGRES_DB=fraerapp_auth
AUTH_POSTGRES_USER=fraerapp_auth
AUTH_POSTGRES_PASSWORD=change-this-auth-db-password
AUTH_PUBLIC_BASE_URL=https://fraerapp.ru
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_DEV_MODE=false
AUTH_MANUAL_LOGIN_LINKS=true
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=https://fraerapp.ru,https://www.fraerapp.ru
AUTH_CORS_ALLOWED_ORIGINS=https://fraerapp.ru,https://www.fraerapp.ru
MAIL_HOSTNAME=mail.fraerapp.ru
SMTP_HOST=mailserver
SMTP_PORT=587
SMTP_USERNAME=noreply@fraerapp.ru
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM=noreply@fraerapp.ru
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=false
