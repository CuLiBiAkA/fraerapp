HTTP_PORT=80
HTTPS_PORT=443
BUILDER_PORT=8090
APP_BIND_IP=127.0.0.1
AUTH_JWT_SECRET=change-this-long-random-shared-secret
POSTGRES_DB=fraerapp
POSTGRES_USER=fraerapp
POSTGRES_PASSWORD=change-this-api-db-password
AUTH_POSTGRES_DB=fraerapp_auth
AUTH_POSTGRES_USER=fraerapp_auth
AUTH_POSTGRES_PASSWORD=change-this-auth-db-password
AUTH_PUBLIC_BASE_URL=https://fraerapp.ru
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
AUTH_DEV_MODE=false
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:8090,https://fraerapp.ru
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:8090,https://fraerapp.ru
MAIL_HOSTNAME=mail.fraerapp.ru
SMTP_HOST=mailserver
SMTP_PORT=587
SMTP_USERNAME=noreply@fraerapp.ru
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM=noreply@fraerapp.ru
SMTP_AUTH=true
SMTP_STARTTLS_ENABLE=true
SMTP_STARTTLS_REQUIRED=false

# Observability stack. Grafana is reachable from the server LAN/IP; Prometheus and Loki stay local.
GRAFANA_BIND_IP=0.0.0.0
OBSERVABILITY_INTERNAL_BIND_IP=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-strong-grafana-password
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
LOKI_PORT=3100
